# ── Workday connection ───────────────────────────────────────────────
# Set MOCK_MODE=true to run entirely off local JSON fixtures in mock_data/
# (no Workday tenant needed) — use this for your first local test.
MOCK_MODE=true

# Your Workday tenant's REST/RaaS base, e.g. https://wd2-impl-services1.workday.com/ccx
WORKDAY_BASE_URL=https://<your-tenant>.workday.com/ccx
WORKDAY_TENANT=your_tenant_name

# OAuth 2.0 (Integration System User / ISU backed client credentials grant)
# Created in Workday: Register API Client for Integrations
WORKDAY_TOKEN_URL=https://<your-tenant>.workday.com/ccx/oauth2/<tenant>/token
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=
WORKDAY_REFRESH_TOKEN=

# How long to cache a pulled RAAS report in memory before re-fetching (seconds)
REPORT_CACHE_TTL_SECONDS=300

# ── MCP server transport ─────────────────────────────────────────────
# "stdio" for local Claude Desktop testing, "streamable-http" for enterprise
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8787
